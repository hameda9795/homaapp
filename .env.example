# Database (PostgreSQL)
# For local development:
DATABASE_URL="postgresql://user:password@localhost:5432/jobauto?schema=public"
# For Vercel Postgres (automatically set by Vercel):
# POSTGRES_URL="postgres://..."

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
# For production on Vercel:
# NEXTAUTH_URL="https://homaapp.vercel.app"
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-a-random-string"

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI (for cover letter generation)
OPENAI_API_KEY="sk-your-openai-api-key"

# Hunter.io (Primary email finder - Recommended!)
# Get your API key at: https://hunter.io/api
HUNTER_API_KEY="your-hunter-api-key"

# RapidAPI (JSearch & Website Contacts Scraper - Fallback)
RAPIDAPI_KEY="your-rapidapi-key"

# Google Search API (Serper.dev) - Optional, for finding company websites
SERPER_API_KEY="your-serper-api-key"

# Vercel Blob (for resume uploads)
# This is automatically set by Vercel when you add Blob storage
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
